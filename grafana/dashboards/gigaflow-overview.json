{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Model Service - Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": null,
      "targets": [
        {
          "expr": "rate(starlette_requests_total[5m])",
          "legendFormat": "{{method}} {{path_template}} {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Model Service - Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": null,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(starlette_requests_processing_time_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Prediction Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": null,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Predictions Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": null,
      "targets": [
        {
          "expr": "sum(predictions_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "title": "Predictions by Sentiment",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": null,
      "targets": [
        {
          "expr": "predictions_total",
          "legendFormat": "{{sentiment}}"
        }
      ]
    },
    {
      "title": "Data Drift Score",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "datasource": null,
      "targets": [
        {
          "expr": "sentiment_data_drift_score",
          "legendFormat": "Drift Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No Drift" }, "1": { "text": "DRIFT DETECTED" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "title": "Data Drift P-Value",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "datasource": null,
      "targets": [
        {
          "expr": "sentiment_data_drift_p_value",
          "legendFormat": "P-Value"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "green", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": null,
      "targets": [
        {
          "expr": "kafka_consumergroup_lag",
          "legendFormat": "{{consumergroup}} - {{topic}} [{{partition}}]"
        }
      ]
    },
    {
      "title": "Predictions / min",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": null,
      "targets": [
        {
          "expr": "sum(rate(predictions_total[5m])) * 60",
          "legendFormat": "pred/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 1 },
        "overrides": []
      }
    },
    {
      "title": "Prediction Input Length (avg)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": null,
      "targets": [
        {
          "expr": "rate(prediction_input_length_chars_sum[5m]) / rate(prediction_input_length_chars_count[5m])",
          "legendFormat": "Avg chars"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["gigaflow", "mlops"],
  "templating": { "list": [] },
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "title": "GigaFlow MLOps Overview",
  "uid": "gigaflow-overview"
}
